# =============================================================
# habit-tracker-pwa — пример конфигурации
# Скопируй файл в .env и заполни своими данными
# cp .env.example .env
# =============================================================

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8000

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=habits
DB_USER=habits_user
DB_PASSWORD=change_me_to_strong_password

# --- JWT ---
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_to_random_string_at_least_48_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- VAPID (Web Push) ---
# Сгенерировать пару ключей:
# python -m app.scripts.generate_vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=mailto:you@example.com
